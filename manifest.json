{
  "manifest_version": 3,
  "name": "KULA-Hub Job Autofill",
  "version": "1.0.0",
  "description": "Queues job links, extracts job details, and submits them into the Resume Builder Add Job form.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "KULA-Hub Support",
    "default_popup": "popup.html",
    "default_icon": "img/icon-128.png"
  },
  "icons": {
    "128": "img/icon-128.png"
 },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["job-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["app-content.js"],
      "run_at": "document_idle"
    }
  ]
}
